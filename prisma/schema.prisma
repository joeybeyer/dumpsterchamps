generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model State {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  abbr        String
  description String?
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cities      City[]
}

model City {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  stateId           String
  description       String?
  metaTitle         String?
  metaDesc          String?
  content           String?
  phone             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  climate           String?
  county            String?
  latitude          Float?
  longitude         Float?
  permits           String?
  population        String?
  whyChooseUs       String?
  aiDescription     String?
  aiGeneratedAt     DateTime?
  heroImageUrl      String?
  gbpEmbed          String?
  googleReviewUrl   String?
  state             State              @relation(fields: [stateId], references: [id])
  blogs             CityBlog[]
  faqs              CityFAQ[]
  neighborhoods     Neighborhood[]
  neighborhoodPages NeighborhoodPage[]
  reviews        CityReview[]

  @@index([stateId])
}

model Neighborhood {
  id          String   @id @default(cuid())
  name        String
  slug        String
  cityId      String
  description String?
  zipCodes    String?
  createdAt   DateTime @default(now())
  city        City     @relation(fields: [cityId], references: [id])

  @@unique([cityId, slug])
  @@index([cityId])
}

model CityFAQ {
  id        String   @id @default(cuid())
  cityId    String
  question  String
  answer    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  city      City     @relation(fields: [cityId], references: [id])

  @@index([cityId])
}

model CityBlog {
  id            String    @id @default(cuid())
  cityId        String
  title         String
  slug          String    @unique
  content       String
  excerpt       String?
  nextBlogId    String?
  prevBlogId    String?
  metaTitle     String?
  metaDesc      String?
  published     Boolean   @default(true)
  isAiGenerated Boolean   @default(false)
  aiGeneratedAt DateTime?
  templateId    Int?
  heroImageUrl  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  city          City      @relation(fields: [cityId], references: [id])

  @@index([cityId])
}

model NeighborhoodPage {
  id            String    @id @default(cuid())
  cityId        String
  name          String
  slug          String
  content       String
  zipCodes      String?
  landmarks     String?
  neighborSlugs String?
  metaTitle     String?
  metaDesc      String?
  heroImageUrl  String?
  aiGeneratedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  city          City      @relation(fields: [cityId], references: [id])

  @@unique([cityId, slug])
  @@index([cityId])
}

model DumpsterSize {
  id          String   @id @default(cuid())
  size        Int
  slug        String   @unique
  name        String
  description String?
  dimensions  String?
  capacity    String?
  idealFor    String?
  priceRange  String?
  content     String?
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  content     String?
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String
  published Boolean  @default(false)
  metaTitle String?
  metaDesc  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id           String   @id @default(cuid())
  type         String
  name         String
  email        String
  phone        String?
  city         String?
  state        String?
  projectType  String?
  dumpsterSize String?
  message      String?
  source       String?
  spam         Boolean  @default(false)
  spamReason   String?
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([phone])
  @@index([createdAt])
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  metaTitle String?
  metaDesc  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessLocation {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  address         String
  city            String
  state           String
  stateAbbr       String
  zip             String
  phone           String
  latitude        Float
  longitude       Float
  googleMapsEmbed String?
  googlePlaceId   String?
  isPrimary       Boolean  @default(false)
  serviceRadius   Int      @default(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CityReview {
  id        String   @id @default(cuid())
  cityId    String
  author    String
  rating    Int
  text      String
  date      String?
  source    String   @default("google")
  createdAt DateTime @default(now())
  city      City     @relation(fields: [cityId], references: [id])

  @@index([cityId])
}
